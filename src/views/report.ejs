<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Report: <%= date %></title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <%- include('partials/header', { page: 'reports' }) %>

  <main>
    <div class="page-header">
      <a href="/" class="back-link">← All Reports</a>
      <h2>Report: <%= date %></h2>
    </div>
    <report-viewer date="<%= date %>">
      <pre slot="raw"><%- content.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;') %></pre>
    </report-viewer>

    <div class="regenerate">
      <button id="regenerate-btn" data-date="<%= date %>">Regenerate Report</button>
    </div>
  </main>

  <script type="module" src="/components/report-viewer.js"></script>
  <script type="module" src="/components/regenerate-form.js"></script>
</body>
</html>
